# ============================================================
#  n8nar-meta-ads-mcp  —  Environment Variables
#  انسخ الملف ده لـ .env.local للتشغيل المحلي،
#  وحط نفس القيم في Vercel → Settings → Environment Variables
# ============================================================

# (1) MCP URL token — عشوائي 48 حرف أو أكتر.
#     ده اللي بيتحط في رابط الـ connector: /api/mcp/<MCP_BEARER_TOKEN>
#     توليد سريع:  openssl rand -hex 32
MCP_BEARER_TOKEN=

# (2) Meta System User access token (من Business Manager).
#     ⚠️ ماتحطهوش هنا في الريبو خالص — يتحط في Vercel env vars بس.
META_ACCESS_TOKEN=

# (3) إصدار Meta Graph API
META_API_VERSION=v22.0

# (4) Supabase — غيّر <your-project-ref> بالـ ref بتاعك
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
